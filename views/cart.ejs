<%- include('./partials/header') %>

<div class="w-full min-h-screen px-20 py-16 bg-zinc-50">
    <h1 class="text-3xl font-semibold mb-8">My Cart</h1>

    <% if (!user.cart || user.cart.length === 0) { %>
        <div class="bg-white rounded-lg shadow p-8">
            <p class="text-lg">Your cart is empty.</p>
            <a href="/shop" class="inline-block mt-4 px-4 py-2 rounded bg-blue-600 text-white">Go to Shop</a>
        </div>
    <% } else { %>
        <div class="grid grid-cols-3 gap-6">
            <div class="col-span-2 space-y-4">
                <% user.cart.forEach(function(item) { %>
                    <div class="bg-white rounded-lg shadow p-4 flex items-center gap-4">
                        <div class="w-32 h-32 rounded overflow-hidden bg-[#<%= item.bgcolor %>] flex items-center justify-center">
                            <img class="h-24" src="data:image/jpeg;base64,<%= item.image.toString('base64') %>" alt="">
                        </div>
                        <div class="flex-1">
                            <h3 class="text-lg font-medium"><%= item.name %></h3>
                            <p>Price: ₹ <%= item.price %></p>
                            <p>Discount: ₹ <%= item.discount || 0 %></p>
                        </div>
                        <div class="font-semibold">
                            ₹ <%= Number(item.price || 0) - Number(item.discount || 0) %>
                        </div>
                    </div>
                <% }) %>
            </div>

            <div class="bg-white rounded-lg shadow p-6 h-fit">
                <h2 class="text-xl font-semibold mb-4">Price Breakdown</h2>
                <div class="space-y-2">
                    <div class="flex justify-between">
                        <span>Total MRP</span>
                        <span>₹ <%= subtotal %></span>
                    </div>
                    <div class="flex justify-between">
                        <span>Total Discount</span>
                        <span>- ₹ <%= totalDiscount %></span>
                    </div>
                    <div class="flex justify-between">
                        <span>Platform Fee</span>
                        <span>₹ <%= platformFee %></span>
                    </div>
                    <hr class="my-3">
                    <div class="flex justify-between font-semibold text-lg">
                        <span>Total Amount</span>
                        <span>₹ <%= bill %></span>
                    </div>
                </div>
            </div>
        </div>
    <% } %>
</div>

<%- include('./partials/footer') %>
