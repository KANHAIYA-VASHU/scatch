<%- include('./partials/header') %>

<% if (success.length > 0) { %>
    <div class="absolute top-5 left-1/2 -translate-x-1/2 p-3 rounded-md bg-blue-500 text-white">
        <%= success %>
    </div>
<% } %>

<% if (error.length > 0) { %>
    <div class="absolute top-20 left-1/2 -translate-x-1/2 p-3 rounded-md bg-red-500 text-white">
        <%= error %>
    </div>
<% } %>

<div class="min-h-screen px-10 py-10 bg-zinc-50">
    <div class="grid grid-cols-3 gap-6">
        <main class="col-span-1 bg-white p-6 shadow rounded-md h-fit">
            <h2 class="text-xl font-bold mb-4">Create New Product</h2>
            <form autocomplete="off" action="/products/create" method="post" enctype="multipart/form-data">
                <div class="mb-4">
                    <label class="block mb-2 font-medium">Product Image *</label>
                    <input name="image" type="file" class="py-2 px-2 border rounded w-full" accept="image/*" required>
                </div>

                <div class="grid grid-cols-1 gap-3">
                    <input name="name" type="text" placeholder="Product Name *" class="border p-2 rounded w-full" required>
                    <input name="price" type="number" min="0" step="0.01" placeholder="Product Price *" class="border p-2 rounded w-full" required>
                    <input name="discount" type="number" min="0" step="0.01" placeholder="Discount Price (optional)" class="border p-2 rounded w-full">
                    <input name="bgcolor" type="text" placeholder="Background Color (e.g. F2F2F2) *" class="border p-2 rounded w-full" required>
                    <input name="panelcolor" type="text" placeholder="Panel Color (e.g. FFFFFF) *" class="border p-2 rounded w-full" required>
                    <input name="textcolor" type="text" placeholder="Text Color (optional, default 000000)" class="border p-2 rounded w-full">
                </div>

                <p class="text-xs text-zinc-500 mt-3">Fields marked * are required.</p>
                <input class="px-5 py-2 rounded mt-4 bg-blue-500 text-white w-full" type="submit" value="Create Product">
            </form>
        </main>

        <section class="col-span-2 bg-white p-6 shadow rounded-md">
            <div class="flex justify-between items-center mb-4">
                <h2 class="text-xl font-bold">All Products</h2>
                <form action="/products/delete-all" method="post" onsubmit="return confirm('Delete all products?');">
                    <button class="px-3 py-2 rounded bg-red-600 text-white" type="submit">Delete All</button>
                </form>
            </div>

            <% if (!products || products.length === 0) { %>
                <p class="text-zinc-600">No products found.</p>
            <% } else { %>
                <div class="grid grid-cols-2 gap-4">
                    <% products.forEach(function(product){ %>
                        <div class="border rounded-md overflow-hidden">
                            <div class="h-40 flex items-center justify-center bg-[#<%= product.bgcolor %>]">
                                <img class="h-28" src="data:image/jpeg;base64,<%= product.image.toString('base64') %>" alt="">
                            </div>
                            <div class="p-3 bg-[#<%= product.panelcolor %>]">
                                <h3 class="font-semibold text-[#<%= product.textcolor || '000000' %>]"><%= product.name %></h3>
                                <p class="text-sm">Price: ₹ <%= product.price %></p>
                                <p class="text-sm">Discount: ₹ <%= product.discount || 0 %></p>
                                <div class="flex gap-2 mt-3">
                                    <a href="/products/edit/<%= product._id %>" class="px-3 py-1 rounded bg-zinc-800 text-white text-sm">Edit</a>
                                    <form action="/products/delete/<%= product._id %>" method="post" onsubmit="return confirm('Delete this product?');">
                                        <button type="submit" class="px-3 py-1 rounded bg-red-600 text-white text-sm">Delete</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </section>
    </div>
</div>

<%- include('./partials/footer') %>
