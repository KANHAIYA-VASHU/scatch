<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="font-['helvetica_now_display']">
    <nav class="w-full flex justify-between px-5 py-3">
        <a href="/" class="text-xl font-semibold">Scatch</a>
        <% var loggedin = typeof loggedin !== "undefined" ? loggedin : true %>
        <% var navRole = typeof navRole !== "undefined" ? navRole : "user" %>
        <% if(loggedin && navRole === "user"){ %>
            <div class="flex gap-5">
                <a href="/shop">Shop</a>
                <a href="/cart">Cart</a>
                <a href="/account">My Account</a>
                <a class="text-red-600" href="/users/logout">Logout</a>
            </div>
        <% } %>

        <% if(loggedin && navRole === "owner"){ %>
            <div class="flex gap-5">
                <a href="/owners/admin">Owner Dashboard</a>
                <a href="/owners/settings">Owner Settings</a>
                <a class="text-red-600" href="/owners/logout">Logout</a>
            </div>
        <% } %>
    </nav>
