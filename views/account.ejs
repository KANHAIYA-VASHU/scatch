<%- include('./partials/header') %>

<% if (success && success.length > 0) { %>
    <div class="absolute top-5 left-1/2 -translate-x-1/2 p-3 rounded-md bg-blue-500 text-white">
        <%= success %>
    </div>
<% } %>

<% if (error && error.length > 0) { %>
    <div class="absolute top-20 left-1/2 -translate-x-1/2 p-3 rounded-md bg-red-500 text-white">
        <%= error %>
    </div>
<% } %>

<div class="w-full min-h-screen px-8 md:px-20 py-10 md:py-16 bg-zinc-50">
    <h1 class="text-3xl font-semibold mb-8">My Account</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <section class="bg-white rounded-lg shadow p-6">
            <h2 class="text-lg font-semibold mb-4">Profile</h2>
            <form action="/account/profile/update" method="post" class="space-y-3">
                <input
                    type="text"
                    name="fullname"
                    value="<%= user?.fullname || '' %>"
                    placeholder="Full Name"
                    class="w-full border rounded px-3 py-2"
                    required
                >
                <input
                    type="email"
                    value="<%= user?.email || '' %>"
                    class="w-full border rounded px-3 py-2 bg-zinc-100"
                    disabled
                >
                <input
                    type="text"
                    name="contact"
                    value="<%= user?.contact || '' %>"
                    placeholder="Contact Number"
                    class="w-full border rounded px-3 py-2"
                >
                <input
                    type="text"
                    name="picture"
                    value="<%= user?.picture || '' %>"
                    placeholder="Profile image URL (optional)"
                    class="w-full border rounded px-3 py-2"
                >
                <button type="submit" class="px-4 py-2 rounded bg-blue-600 text-white">Update Profile</button>
            </form>
        </section>

        <section class="bg-white rounded-lg shadow p-6">
            <h2 class="text-lg font-semibold mb-4">Quick Summary</h2>
            <p class="mb-2"><span class="font-medium">Items in cart:</span> <%= user?.cart?.length || 0 %></p>
            <p class="mb-2"><span class="font-medium">Pending orders:</span> <%= pendingOrders?.length || 0 %></p>
            <p class="mb-2"><span class="font-medium">Current orders:</span> <%= currentOrders?.length || 0 %></p>
            <p class="mb-2"><span class="font-medium">Past orders:</span> <%= pastOrders?.length || 0 %></p>
            <div class="mt-5 flex gap-3">
                <a href="/shop" class="px-4 py-2 rounded bg-zinc-800 text-white">Shop</a>
                <a href="/cart" class="px-4 py-2 rounded bg-blue-600 text-white">Cart</a>
            </div>
        </section>
    </div>

    <section class="bg-white rounded-lg shadow p-6 mt-6">
        <h2 class="text-lg font-semibold mb-4">Orders</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div class="border rounded-md p-4">
                <h3 class="font-semibold mb-3">Pending</h3>
                <% if (!pendingOrders || pendingOrders.length === 0) { %>
                    <p class="text-sm text-zinc-500">No pending orders.</p>
                <% } else { %>
                    <% pendingOrders.forEach(function(order){ %>
                        <div class="mb-3 p-3 bg-zinc-50 rounded">
                            <p class="text-sm font-medium"><%= order.orderId %></p>
                            <p class="text-sm">Items: <%= order.itemsCount %></p>
                            <p class="text-sm">Amount: ₹ <%= order.totalAmount %></p>
                        </div>
                    <% }) %>
                <% } %>
            </div>

            <div class="border rounded-md p-4">
                <h3 class="font-semibold mb-3">Current</h3>
                <% if (!currentOrders || currentOrders.length === 0) { %>
                    <p class="text-sm text-zinc-500">No current orders.</p>
                <% } else { %>
                    <% currentOrders.forEach(function(order){ %>
                        <div class="mb-3 p-3 bg-zinc-50 rounded">
                            <p class="text-sm font-medium"><%= order.orderId %></p>
                            <p class="text-sm">Items: <%= order.itemsCount %></p>
                            <p class="text-sm">Amount: ₹ <%= order.totalAmount %></p>
                            <p class="text-sm">ETA: <%= order.eta || "Not available" %></p>
                        </div>
                    <% }) %>
                <% } %>
            </div>

            <div class="border rounded-md p-4">
                <h3 class="font-semibold mb-3">Past</h3>
                <% if (!pastOrders || pastOrders.length === 0) { %>
                    <p class="text-sm text-zinc-500">No past orders.</p>
                <% } else { %>
                    <% pastOrders.forEach(function(order){ %>
                        <div class="mb-3 p-3 bg-zinc-50 rounded">
                            <p class="text-sm font-medium"><%= order.orderId %></p>
                            <p class="text-sm">Items: <%= order.itemsCount %></p>
                            <p class="text-sm">Amount: ₹ <%= order.totalAmount %></p>
                            <p class="text-sm text-green-600">Delivered</p>
                        </div>
                    <% }) %>
                <% } %>
            </div>
        </div>
    </section>

    <section class="bg-white rounded-lg shadow p-6 mt-6">
        <h2 class="text-lg font-semibold mb-4">Track Orders</h2>
        <% const allOrders = [...(pendingOrders || []), ...(currentOrders || []), ...(pastOrders || [])]; %>
        <% if (!allOrders.length) { %>
            <p class="text-sm text-zinc-500">No orders available for tracking.</p>
        <% } else { %>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <% allOrders.forEach(function(order){ %>
                    <div class="border rounded-md p-4 bg-zinc-50">
                        <p class="font-medium"><%= order.orderId %></p>
                        <p class="text-sm">Status: <span class="capitalize"><%= order.status %></span></p>
                        <p class="text-sm">Tracking ID: <%= order.trackingId || "Not assigned" %></p>
                        <p class="text-sm">Tracking Update: <%= order.trackingStatus || "No update" %></p>
                        <p class="text-sm">ETA: <%= order.eta || "Not available" %></p>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </section>

    <section class="bg-white rounded-lg shadow p-6 mt-6">
        <h2 class="text-lg font-semibold mb-4">Shipping Addresses</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
            <form action="/account/addresses" method="post" class="space-y-3 border rounded-md p-4">
                <h3 class="font-semibold">Add New Address</h3>
                <input name="fullName" type="text" placeholder="Full Name" class="w-full border rounded px-3 py-2" required>
                <input name="phone" type="text" placeholder="Phone" class="w-full border rounded px-3 py-2" required>
                <input name="line1" type="text" placeholder="Address Line 1" class="w-full border rounded px-3 py-2" required>
                <input name="line2" type="text" placeholder="Address Line 2 (optional)" class="w-full border rounded px-3 py-2">
                <div class="grid grid-cols-2 gap-2">
                    <input name="city" type="text" placeholder="City" class="w-full border rounded px-3 py-2" required>
                    <input name="state" type="text" placeholder="State" class="w-full border rounded px-3 py-2" required>
                    <input name="postalCode" type="text" placeholder="Postal Code" class="w-full border rounded px-3 py-2" required>
                    <input name="country" type="text" placeholder="Country" class="w-full border rounded px-3 py-2" value="India">
                </div>
                <label class="flex items-center gap-2 text-sm">
                    <input name="isDefault" type="checkbox">
                    Set as default
                </label>
                <button type="submit" class="px-4 py-2 rounded bg-blue-600 text-white">Add Address</button>
            </form>

            <div class="space-y-4">
                <% if (!user?.addresses || user.addresses.length === 0) { %>
                    <p class="text-sm text-zinc-500">No shipping addresses added yet.</p>
                <% } else { %>
                    <% user.addresses.forEach(function(address){ %>
                        <form action="/account/addresses/<%= address._id %>/update" method="post" class="border rounded-md p-4 space-y-2">
                            <div class="flex justify-between items-center">
                                <h3 class="font-semibold">Address <%= address.isDefault ? "(Default)" : "" %></h3>
                                <button
                                    type="submit"
                                    formaction="/account/addresses/<%= address._id %>/delete"
                                    formmethod="post"
                                    class="px-3 py-1 rounded bg-red-600 text-white text-sm"
                                    onclick="return confirm('Delete this address?')"
                                >
                                    Delete
                                </button>
                            </div>
                            <input name="fullName" type="text" value="<%= address.fullName %>" class="w-full border rounded px-3 py-2" required>
                            <input name="phone" type="text" value="<%= address.phone %>" class="w-full border rounded px-3 py-2" required>
                            <input name="line1" type="text" value="<%= address.line1 %>" class="w-full border rounded px-3 py-2" required>
                            <input name="line2" type="text" value="<%= address.line2 %>" class="w-full border rounded px-3 py-2">
                            <div class="grid grid-cols-2 gap-2">
                                <input name="city" type="text" value="<%= address.city %>" class="w-full border rounded px-3 py-2" required>
                                <input name="state" type="text" value="<%= address.state %>" class="w-full border rounded px-3 py-2" required>
                                <input name="postalCode" type="text" value="<%= address.postalCode %>" class="w-full border rounded px-3 py-2" required>
                                <input name="country" type="text" value="<%= address.country %>" class="w-full border rounded px-3 py-2">
                            </div>
                            <label class="flex items-center gap-2 text-sm">
                                <input name="isDefault" type="checkbox" <%= address.isDefault ? "checked" : "" %>>
                                Set as default
                            </label>
                            <button type="submit" class="px-4 py-2 rounded bg-zinc-800 text-white text-sm">Update Address</button>
                        </form>
                    <% }) %>
                <% } %>
            </div>
        </div>
    </section>
</div>

<%- include('./partials/footer') %>
